{
  "name": "open-multi-agent",
  "version": "0.1.0",
  "description": "Production-grade multi-agent orchestration framework. Model-agnostic, supports team collaboration, task scheduling, and inter-agent communication.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build",
    "server": "node --import tsx/esm server/index.ts",
    "server:dev": "node --watch --import tsx/esm server/index.ts",
    "ui:install": "npm install --prefix ui --registry https://registry.npmjs.org/",
    "ui:dev": "npm run dev --prefix ui",
    "ui:build": "npm run build --prefix ui",
    "dev:all": "npm run build && concurrently \"npm run server:dev\" \"npm run ui:dev\""
  },
  "keywords": [
    "ai",
    "agent",
    "multi-agent",
    "orchestration",
    "llm",
    "claude",
    "openai",
    "mcp",
    "tool-use",
    "agent-framework"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "openai": "^4.73.0",
    "socket.io": "^4.8.3",
    "tsx": "^4.21.0",
    "uuid": "^13.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
